    order_date;

#10. CATEGORIES WITH THE HIGHEST ROLLING AOV
WITH order_category_totals AS (
    SELECT
        order_date,
        order_id,
        category,
        SUM(amount) AS category_order_value
    FROM amazon_sales.amz_report
    GROUP BY
        order_date,
        order_id,
        category
),
daily_category_aov AS (
    SELECT
        order_date,
        category,
        AVG(category_order_value) AS daily_category_aov
    FROM order_category_totals
    GROUP BY
        order_date,
        category
),
rolling_category_aov AS (
    SELECT
        order_date,
        category,
        AVG(daily_category_aov) OVER (
            PARTITION BY category
            ORDER BY order_date
            ROWS BETWEEN 6 PRECEDING AND CURRENT ROW
        ) AS rolling_7day_aov
    FROM daily_category_aov
)

SELECT
    category,
    ROUND(AVG(rolling_7day_aov), 2) AS average_rolling_aov
FROM rolling_category_aov
GROUP BY category
ORDER BY average_rolling_aov DESC;

#11. OVERALL CATEGORY PERFORMANCE
WITH order_category_totals AS (
    SELECT
        order_id,
        category,
        SUM(amount) AS category_order_value
    FROM amazon_sales.amz_report
    GROUP BY
        order_id,
        category
)

SELECT
    category,
    COUNT(DISTINCT order_id) AS total_orders,
    ROUND(SUM(category_order_value), 2) AS total_revenue,
    ROUND(AVG(category_order_value), 2) AS average_order_value
FROM order_category_totals
GROUP BY category
ORDER BY total_revenue DESC;

#12. PROMOTION PERFORMANCE BY CATEGORY
WITH order_promotion_totals AS (
    SELECT
        order_id,
        category,

        CASE
            WHEN promotion_used = 'No'
                THEN 'No Promotion'
            ELSE 'Promotion'
        END AS promotion_status,

        SUM(amount) AS order_value

    FROM amazon_sales.amz_report

    GROUP BY
        order_id,
        category,
        CASE
            WHEN promotion_used = 'No'
                THEN 'No Promotion'
            ELSE 'Promotion'
        END
)

SELECT
    category,
    promotion_status,
    COUNT(DISTINCT order_id) AS total_orders,
    ROUND(SUM(order_value), 2) AS total_revenue,
    ROUND(AVG(order_value), 2) AS average_order_value
FROM order_promotion_totals
GROUP BY
    category,
    promotion_status
ORDER BY
    category,
    average_order_value DESC;

#13. PROMOTIONAL AOV LIFT BY CATEGORY
WITH order_promotion_totals AS (
    SELECT
        order_id,
        category,

        CASE
            WHEN promotion_used = 'No'
                THEN 'No Promotion'
            ELSE 'Promotion'
        END AS promotion_status,

        SUM(amount) AS order_value

    FROM amazon_sales.amz_report

    GROUP BY
        order_id,
        category,
        CASE
            WHEN promotion_used = 'No'
                THEN 'No Promotion'
            ELSE 'Promotion'
        END
),
promotion_aov AS (
    SELECT
        category,

        AVG(
            CASE
                WHEN promotion_status = 'Promotion'
                THEN order_value
            END
        ) AS promotion_aov,

        AVG(
            CASE
                WHEN promotion_status = 'No Promotion'
                THEN order_value
            END
        ) AS no_promotion_aov

    FROM order_promotion_totals
    GROUP BY category
)

SELECT
    category,
    ROUND(promotion_aov, 2) AS promotion_aov,
    ROUND(no_promotion_aov, 2) AS no_promotion_aov,

    ROUND(
        promotion_aov - no_promotion_aov,
        2
    ) AS aov_difference,

    ROUND(
        (
            promotion_aov - no_promotion_aov
        ) * 100.0
        / NULLIF(no_promotion_aov, 0),
        2
    ) AS promotional_aov_lift_pct

FROM promotion_aov
ORDER BY promotional_aov_lift_pct DESC;
